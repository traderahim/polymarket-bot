# Copy this file to .env for local testing (never commit real keys to GitHub!)
# On Railway, set these in the Variables tab instead.

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional: Telegram notifications (free) ──────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot to get your Chat ID
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Trading mode ─────────────────────────────────────────────────────────────
# PAPER_MODE=true   → paper trading only, no real money (safe to test)
# PAPER_MODE=false  → LIVE trading with real USDC (only when you're ready!)
PAPER_MODE=true
